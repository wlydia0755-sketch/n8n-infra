# =========================

# 敏感配置文件

# =========================

# 真实环境变量，不能提交

.env

# 各类环境变量变体，也不能提交

.env.*

# 但保留环境变量模板文件

!.env.example

# =========================

# 数据库 / n8n 备份文件

# =========================

# 备份目录通常可能包含数据库备份、workflow 备份、敏感数据

backup/

# 常见备份文件

*.dump
*.backup

# =========================

# Docker 数据卷

# =========================

# n8n / PostgreSQL 本地数据卷，不提交

n8n_data/
postgres_data/
data/

# =========================

# 日志文件

# =========================

*.log
logs/

# =========================

# 临时文件

# =========================

*.tmp
*.temp
*.bak
*.swp

# =========================

# 编辑器 / IDE 配置

# =========================

.vscode/
.idea/

# =========================

# 系统文件

# =========================

Thumbs.db
Desktop.ini
.DS_Store

# =========================

# Node / Python 缓存

# =========================

node_modules/
**pycache**/
*.pyc
.venv/
venv/

# =========================

# Excel 临时文件

# =========================

~$*.xlsx
~$*.xls

# =========================

# Kalodata 原始 Excel 数据

# =========================

# Kalodata 原始 Excel 数据暂不提交到 GitHub

workflows/*.xlsx
workflows/*.xls
